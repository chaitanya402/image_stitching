# GenAI Video Editor - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# APPLICATION SETTINGS
# ============================================
DEBUG=false
APP_NAME=GenAI Video Editor
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================
# DATABASE SETTINGS
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_editor
DB_ECHO=false

# ============================================
# REDIS SETTINGS
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600  # 1 hour in seconds

# ============================================
# AWS SETTINGS
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=video-editor-uploads

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_FILE_SIZE_MB=500
ALLOWED_VIDEO_FORMATS=mp4,mov,avi,mkv,webm
UPLOAD_TEMP_DIR=/tmp/video_uploads

# ============================================
# API KEYS (Third-party Services)
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Get from: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ============================================
# PROCESSING SETTINGS
# ============================================
VIDEO_ENHANCEMENT_ENABLED=true
COMPRESSION_QUALITY=85  # 0-100
TARGET_FPS=24
TARGET_RESOLUTION_HEIGHT=1920  # 9:16 aspect ratio

# ============================================
# GPU SETTINGS
# ============================================
USE_GPU=true
CUDA_DEVICE_ID=0

# ============================================
# CELERY SETTINGS (Async Task Queue)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=3600  # 1 hour in seconds

# ============================================
# TIMEOUT SETTINGS
# ============================================
VIDEO_PROCESSING_TIMEOUT=300  # 5 minutes in seconds
API_REQUEST_TIMEOUT=30  # 30 seconds

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ============================================
# CORS SETTINGS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ============================================
# MONITORING & LOGGING
# ============================================
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
PROMETHEUS_ENABLED=true

# ============================================
# ENVIRONMENT
# ============================================
# Options: development, staging, production
ENVIRONMENT=development
